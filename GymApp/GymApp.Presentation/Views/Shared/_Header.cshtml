@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}


<header>
    <nav class="navbar navbar-expand-lg bg-white my-3">
        <div class="container">
            <a class="navbar-brand" href="#">
                <img src="~/images/logo.jpg" alt="" />
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
                    aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav m-auto mb-2 mb-lg-0 mt-3 mt-lg-0">
                    <li class="nav-item">
                        <a class="nav-link @((currentController == "Home" && currentAction == "Index")?"active":"") px-3 py-2 mx-2 fw-bolder fs-5" aria-current="page" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @((currentController == "Members" && currentAction == "Index") ? "active" : "") px-3 py-2 mx-2 fw-bolder fs-5" asp-controller="Members" asp-action="Index">Members</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @((currentController == "Trainers" && currentAction == "Index") ? "active" : "") px-3 py-2 mx-2 fw-bolder fs-5" asp-controller="Trainers" asp-action="Index">Trainers</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @((currentController == "Sessions" && currentAction == "Index") ? "active" : "") px-3 py-2 mx-2 fw-bolder fs-5" asp-controller="Sessions" asp-action="Index">Sessions</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @((currentController == "Plans" && currentAction == "Index") ? "active" : "") px-3 py-2 mx-2 fw-bolder fs-5" asp-controller="Plans" asp-action="Index">Plans</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @((currentController == "Memberships" && currentAction == "Index") ? "active" : "") px-3 py-2 mx-2 fw-bolder fs-5" asp-controller="Memberships" asp-action="Index">Memberships</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @((currentController == "SessionsSchedule" && currentAction == "Index") ? "active" : "") px-3 py-2 mx-2 fw-bolder fs-5" asp-controller="SessionsSchedule" asp-action="Index">Sessions Schedule</a>
                    </li>
                    <li class="nav-item">
                        <form asp-action="Logout" asp-controller="Account" method="post" class="d-inline">
                            <button type="submit"
                                    class="btn btn-link nav-link px-3 py-2 mx-2 fw-bolder fs-5 text-black-alternative">
                                Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>
